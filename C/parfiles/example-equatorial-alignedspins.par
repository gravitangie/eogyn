# example parfile

# binary parameters
q      = 10.  
chi1x0 = 0.
chi1y0 = 0.
chi1z0 = 0.65
chi2x0 = 0.
chi2y0 = 0.
chi2z0 = 0.65

# type of initial conditions
motion = equatorial-eccentric

# orbital parameters
E0  = 0.97
pphi0 = 3.8

# options for different functions
pots = resummed # comment/uncomment to test

# ODE solver settings
dt      = 0.1
tmax    = 5000









