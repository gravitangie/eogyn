# example parfile

# binary parameters
q      = 10.  
chi1x0 = 0.
chi1y0 = 0. 
chi1z0 = 0.65
chi2x0 = 0.
chi2y0 = 0. 
chi2z0 = 0.65

# type of initial conditions
motion = circular

# orbital parameters
x0 = 15.
y0 = 0.
z0 = 0.

# options for different functions
pots = resummed # comment/uncomment to test

# ODE solver settings
dt      = 0.5
tmax    = 5000









